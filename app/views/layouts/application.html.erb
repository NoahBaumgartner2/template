<!DOCTYPE html>
<html lang="de-CH">
  <head>
    <%# TBD: Titel + Beschreibung pro Projekt setzen %>
    <title>Neues Projekt</title>
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col antialiased">
    <%# Flash %>
    <% if flash[:notice] %>
      <div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-ink-900 text-white px-6 py-4 rounded-xl shadow-xl text-sm max-w-sm text-center">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%# TBD: Header / Navigation pro Projekt hier aufbauen %>

    <main class="flex-1">
      <%= yield %>
    </main>

    <%# TBD: Footer pro Projekt hier aufbauen %>
  </body>
</html>
