<%# Platzhalter-Team – pro Projekt anpassen %>
<section class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <h1 class="font-heading text-3xl md:text-5xl font-bold mb-4">Team</h1>
  <p class="text-mist-600 max-w-2xl mb-12">
    Platzhalter: Vorstellung des Teams.
  </p>

  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
    <% 3.times do |i| %>
      <div class="text-center">
        <div class="aspect-square rounded-2xl bg-mist-100 mb-4"></div>
        <h2 class="font-heading text-lg font-semibold">Name <%= i + 1 %></h2>
        <p class="text-mist-600 text-sm">Funktion (Platzhalter)</p>
      </div>
    <% end %>
  </div>
</section>
