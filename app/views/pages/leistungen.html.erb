<%# Platzhalter-Leistungen – pro Projekt anpassen %>
<section class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <h1 class="font-heading text-3xl md:text-5xl font-bold mb-4">Leistungen</h1>
  <p class="text-mist-600 max-w-2xl mb-12">
    Platzhalter: Übersicht über das Angebot.
  </p>

  <div class="grid md:grid-cols-2 gap-6">
    <% [
         ["Leistung 1", "Kurze Beschreibung."],
         ["Leistung 2", "Kurze Beschreibung."],
         ["Leistung 3", "Kurze Beschreibung."],
         ["Leistung 4", "Kurze Beschreibung."]
       ].each do |title, text| %>
      <div class="bg-white rounded-2xl border border-mist-100 p-8">
        <h2 class="font-heading text-xl font-semibold mb-2"><%= title %></h2>
        <p class="text-mist-600 text-sm"><%= text %> (Platzhalter)</p>
      </div>
    <% end %>
  </div>
</section>
