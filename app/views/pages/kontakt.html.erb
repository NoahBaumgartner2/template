<%# Platzhalter-Kontakt – pro Projekt anpassen %>
<section class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <h1 class="font-heading text-3xl md:text-5xl font-bold mb-4">Kontakt</h1>
  <p class="text-mist-600 max-w-2xl mb-12">
    Platzhalter: Adresse, Öffnungszeiten und Kontaktformular.
  </p>

  <div class="grid md:grid-cols-2 gap-12">
    <div class="space-y-4 text-sm">
      <div>
        <p class="font-semibold">Adresse</p>
        <p class="text-mist-600">Musterstrasse 1, 0000 Musterort</p>
      </div>
      <div>
        <p class="font-semibold">Telefon</p>
        <p class="text-mist-600">+41 00 000 00 00</p>
      </div>
      <div>
        <p class="font-semibold">E-Mail</p>
        <a href="mailto:info@example.com" class="text-brand hover:underline">info@example.com</a>
      </div>
    </div>

    <%= form_with url: contact_submit_path, method: :post, class: "space-y-4" do |f| %>
      <%= f.text_field :name, placeholder: "Name",
            class: "w-full rounded-lg border border-mist-100 px-4 py-3 text-sm" %>
      <%= f.email_field :email, placeholder: "E-Mail",
            class: "w-full rounded-lg border border-mist-100 px-4 py-3 text-sm" %>
      <%= f.text_area :message, placeholder: "Nachricht", rows: 5,
            class: "w-full rounded-lg border border-mist-100 px-4 py-3 text-sm" %>
      <%= f.submit "Senden",
            class: "bg-brand text-white px-8 py-3 rounded-full font-medium hover:bg-brand-dark transition-colors cursor-pointer" %>
    <% end %>
  </div>
</section>
